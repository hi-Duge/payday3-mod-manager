{
  "name": "payday3-mod-manager",
  "version": "1.0.55",
  "description": "PAYDAY 3 Mod Manager",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/fixElectronUpdaterGitHub406.js",
    "start": "electron .",
    "prepack": "node -e \"const fs=require('fs'),path=require('path'); const p=path.join(__dirname,'..','icon.ico'); if(fs.existsSync(p)) fs.copyFileSync(p, path.join(__dirname,'icon.ico')); const p2=path.join(__dirname,'..','icon.png'); if(fs.existsSync(p2)&&!fs.existsSync(path.join(__dirname,'icon.ico'))) fs.copyFileSync(p2, path.join(__dirname,'icon.png'));\" && node ensure-icon.js",
    "pack": "electron-builder",
    "dist": "electron-builder",
    "dist:d": "electron-builder --config.directories.output=D:/dist",
    "release": "electron-builder --publish always"
  },
  "author": "the lover of cats the 56th",
  "license": "MIT",
  "overrides": {
    "register-scheme": "0.0.2"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.33.2",
    "to-ico": "^1.1.5"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.1",
    "adm-zip": "^0.5.10",
    "bindings": "^1.5.0",
    "discord-ipc": "^1.0.0",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "node-addon-api": "^8.4.0"
  },
  "build": {
    "afterPack": "./scripts/afterPack.js",
    "appId": "com.payday3modmanager.app",
    "productName": "PAYDAY 3 Mod Manager",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "icon.png",
        "to": "."
      },
      {
        "from": "icon.ico",
        "to": "."
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "signAndEditExecutable": false,
      "icon": "icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hi-Duge",
        "repo": "payday3-mod-manager",
        "private": false
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PAYDAY 3 Mod Manager",
      "menuCategory": "PAYDAY 3 Mod Manager",
      "uninstallDisplayName": "PAYDAY 3 Mod Manager"
    }
  }
}
